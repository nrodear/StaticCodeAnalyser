# ---- Sonar-50 #19/#23/#33 (SCA144-146) -------------------------------------
msgid "Float equality"
msgstr "Float-Gleichheit"

msgid "Raise in destructor"
msgstr "Raise im Destruktor"

msgid "Boolean parameter as flag"
msgstr "Boolean-Parameter als Flag"

