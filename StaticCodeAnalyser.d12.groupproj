<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{7012BB59-6051-481D-B373-92ECC22F6CE1}</ProjectGuid>
    </PropertyGroup>
    <ItemGroup>
        <Projects Include="StaticCodeAnalyserForm\analyser.d12.dproj">
            <Dependencies/>
        </Projects>
        <Projects Include="StaticCodeAnalyserIDE\StaticCodeAnalyserIDE.dproj">
            <Dependencies/>
        </Projects>
        <Projects Include="StaticCodeAnalyserForm\tests\TestProject.dproj">
            <Dependencies/>
        </Projects>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Default.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Default.Personality/>
        </BorlandProject>
    </ProjectExtensions>
    <Target Name="analyser_d12">
        <MSBuild Projects="StaticCodeAnalyserForm\analyser.d12.dproj"/>
    </Target>
    <Target Name="analyser_d12:Clean">
        <MSBuild Projects="StaticCodeAnalyserForm\analyser.d12.dproj" Targets="Clean"/>
    </Target>
    <Target Name="analyser_d12:Make">
        <MSBuild Projects="StaticCodeAnalyserForm\analyser.d12.dproj" Targets="Make"/>
    </Target>
    <Target Name="StaticCodeAnalyserIDE">
        <MSBuild Projects="StaticCodeAnalyserIDE\StaticCodeAnalyserIDE.dproj"/>
