    <Target Name="StaticCodeAnalyserIDE:Clean">
        <MSBuild Projects="StaticCodeAnalyserIDE\StaticCodeAnalyserIDE.dproj" Targets="Clean"/>
    </Target>
    <Target Name="StaticCodeAnalyserIDE:Make">
        <MSBuild Projects="StaticCodeAnalyserIDE\StaticCodeAnalyserIDE.dproj" Targets="Make"/>
    </Target>
    <Target Name="TestProject">
        <MSBuild Projects="StaticCodeAnalyserForm\tests\TestProject.dproj"/>
    </Target>
    <Target Name="TestProject:Clean">
