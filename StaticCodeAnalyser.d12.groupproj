    <Target Name="Make">
        <CallTarget Targets="analyser_d12:Make;StaticCodeAnalyserIDE:Make;TestProject:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
