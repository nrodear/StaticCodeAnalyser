// Branding-Resource fuer das IDE-Plugin (sca_24.bmp als BITMAP-Resource).
//
// Canonical Embarcadero-Pattern fuer IDE-About-Box + Splash-Screen (Source:
// Embarcadero OTAPI-Docs Kapitel 9, David Hoyle):
//   bm := LoadBitmap(HInstance, 'SCA_APP_BMP');
//   SplashScreenServices.AddPluginBitmap(.., bm, ..);
//   IOTAAboutBoxServices.AddPluginInfo(.., bm, ..);
//
// WICHTIG: 'BITMAP'-Resource-Type, NICHT 'RCDATA' - LoadBitmap erwartet
// genau diesen Typ. Datei muss ein Windows-BMP sein (kein PNG, kein ICO).
//
// Standalone-EXE braucht diese Resource NICHT - sie nutzt das auto-
// MAINICON-Pattern via <Icon_MainIcon> im dproj (siehe branding\sca.ico).
//
// Build-Integration (NUR IDE-Plugin):
//   * <RcCompile Include="..\branding\sca_branding.rc"/> im IDE-dproj
//   * {$R 'sca_branding.res'} im IDE-dpk (Pfad relativ zur dpk, BRCC32
//     legt das Output neben die dpk).

LANGUAGE 0, 0

SCA_APP_BMP BITMAP "sca_24.bmp"

// ICON-Resource fuer das Window-Caption-Icon des IDE-Plugin-DockForms im
// Float-Mode. Multi-Res 16/32/48 - Windows waehlt selbst je nach DPI /
// Caption-Hoehe / Alt-Tab-Anzeige.
// WICHTIG: kleines ICO ('sca_small.ico'), NICHT das volle 'sca.ico' mit
// 256x256-Sub-Icon. BRCC32 ist 16-bit-Erbe und kippt mit 'Allocate failed'
// beim 256er (256*256*4 = 256 KB sprengt das interne Allocation-Limit).
// Standalone-EXE nutzt das volle sca.ico via Delphi's eigener MAINICON-
// Toolchain (kein BRCC32-Limit dort).
SCA_APP_ICO ICON "sca_small.ico"
