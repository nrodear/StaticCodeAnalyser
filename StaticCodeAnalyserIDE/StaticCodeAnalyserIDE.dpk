  uHardcodedSecret in '..\StaticCodeAnalyserForm\sources\Detectors\uHardcodedSecret.pas',
  uFormatMismatch in '..\StaticCodeAnalyserForm\sources\Detectors\uFormatMismatch.pas',
  uUnusedUses in '..\StaticCodeAnalyserForm\sources\Detectors\uUnusedUses.pas',
  uNilDeref in '..\StaticCodeAnalyserForm\sources\Detectors\uNilDeref.pas',
  uMissingFinally in '..\StaticCodeAnalyserForm\sources\Detectors\uMissingFinally.pas',
  uDivByZero in '..\StaticCodeAnalyserForm\sources\Detectors\uDivByZero.pas',
  uDeadCode in '..\StaticCodeAnalyserForm\sources\Detectors\uDeadCode.pas',
  uLongMethod in '..\StaticCodeAnalyserForm\sources\Detectors\uLongMethod.pas',
