  uIDEStatsTiles in 'uIDEStatsTiles.pas',
  uIDEHelpPanel in 'uIDEHelpPanel.pas',
  uIDEExportMenu in 'uIDEExportMenu.pas',
  uIDEEditorIntegration in 'uIDEEditorIntegration.pas',
  uIDEStatusBar in 'uIDEStatusBar.pas',
  uIDEThemeIntegration in 'uIDEThemeIntegration.pas',
  uIDEAnalyseProgress in 'uIDEAnalyseProgress.pas',
  uIDEGridTooltip in 'uIDEGridTooltip.pas',
  uIDELifecycle in 'uIDELifecycle.pas',
  uIDEAnalyseRunner in 'uIDEAnalyseRunner.pas',
  // ---- UI ----
