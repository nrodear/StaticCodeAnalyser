  uFindingGridRenderer in '..\StaticCodeAnalyserForm\sources\UI\uFindingGridRenderer.pas',
  uFindingFilter in '..\StaticCodeAnalyserForm\sources\UI\uFindingFilter.pas',
  uLocalization in '..\StaticCodeAnalyserForm\sources\UI\uLocalization.pas',
  // ---- Parsing ----
  uAstNode in '..\StaticCodeAnalyserForm\sources\Parsing\uAstNode.pas',
  uLexer in '..\StaticCodeAnalyserForm\sources\Parsing\uLexer.pas',
  uParser2 in '..\StaticCodeAnalyserForm\sources\Parsing\uParser2.pas',
  // ---- Infrastructure ----
